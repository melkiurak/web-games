generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id Int @id @default(autoincrement())
  name String
  rating Float?
  first_release_date Int?
  summary String? @db.Text
  price  Float?
  min_requirements String?
  max_requirements String?
  cover_url String?
  genres  Genre[]
  platforms String?
  screenshots String?
  videos String?
  companies Company[]
  comments Comment[]
  @@map("games")
}
model Company {
  id Int @id @default(autoincrement())
  name String
  game Game[]
}
model Genre {
  id Int @id @default(autoincrement())
  name String
  game Game[]
}
model Comment {
  id Int @id @default(autoincrement())
  text String
  gameId Int
  game Game @relation(fields:[gameId], references: [id])
}