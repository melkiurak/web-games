generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id Int @id @default(autoincrement())
  name String
  description String
  rating Float?
  date DateTime
  platforms Platform[]
  genres Genre[]
  poster String
  price Float?
  trailer String[]
  screenshots  String[]
  minReqId Int? @unique
  recReqId Int? @unique
  minReq   SystemRequirement? @relation("MinReq", fields: [minReqId], references: [id])?
  recReq   SystemRequirement? @relation("RecReq", fields: [recReqId], references: [id])?
}
model SystemRequirement {
  id Int @id @default(autoincrement())
  os String
  сpu String
  memory String
  gpu String
  directX String
  storage String
  gameMin  Game? @relation("MinReq")
  gameRec  Game? @relation("RecReq")
}
model Genre {
  id Int @id @default(autoincrement())
  name String @unique
  games Game[]
}
model Platform {
  id Int @id @default(autoincrement())
  name String @unique
  games Game[]
}