generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id                 BigInt    @id @default(autoincrement()) 
  name               String
  rating             Decimal?  
  first_release_date BigInt?   
  summary            String?   @db.Text
  price              Decimal?  
  min_requirements   String?
  max_requirements   String?
  cover_url          String?
  genres             String?   
  platforms          String?
  screenshots        String?
  videos             String?
  companies          String?  
  
  // Добавляем связь для комментариев
  comments           Comment[]

  @@map("games")
}

model Comment {
  id     Int    @id @default(autoincrement())
  text   String
  gameId BigInt 
  game   Game   @relation(fields: [gameId], references: [id])
}