generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id                    Int      @id @default(autoincrement())
  externalId            Int      @unique 
  name                  String
  description           String   @db.Text 
  date                  DateTime
  poster                String
  price                 Float?

  // Rating
  aggregatedRatingCount Int      @default(0)
  metaScore             Float?    
  recommendations       Int      @default(0)
  hypes                 Int      @default(0) 

  // Medias 
  trailer               String[]
  screenshots           String[]

  // Connections
  platforms             Platform[]
  genres                Genre[]
  publishers            Publisher[]
  categories            Category[]

  // SystemRequirement
  minReqId              String?  @unique
  recReqId              String?  @unique
  minReq                SystemRequirement? @relation("MinReq", fields: [minReqId], references: [id])
  recReq                SystemRequirement? @relation("RecReq", fields: [recReqId], references: [id])
}
model SystemRequirement {
  id String @id @default(uuid())
  os String
  cpu String
  memory String
  gpu String
  directX String
  storage String
  gameMin  Game? @relation("MinReq")
  gameRec  Game? @relation("RecReq")
}
model Genre {
  id Int @id @default(autoincrement())
  name String @unique
  games Game[]
}
model Platform {
  id Int @id @default(autoincrement())
  name String @unique
  games Game[]
}
model Publisher {
  id Int @id @default(autoincrement())
  name String @unique
  games Game[]
}
model Category { 
  id    Int    @id @default(autoincrement())
  name  String @unique
  games Game[]
}